{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "KSE.DistributedSystems.NotificationService": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*",
  "SendGrid": {
    "ApiKey": "API-KEY",
    "FromEmail": "delivery@ukhyl.pp.ua"
  },
  "Resilience": {
    "CircuitBreaker": {
      "HandledEventsAllowedBeforeBreaking": 3,
      "DurationOfBreak": "00:00:30",
      "SamplingDuration": 60,
      "MinimumThroughput": 5
    },
    "Retry": {
      "MaxRetryAttempts": 3,
      "BaseDelay": "00:00:02",
      "MaxDelay": "00:00:30",
      "UseJitter": true
    },
    "Timeout": {
      "DefaultTimeout": "00:00:30",
      "DatabaseTimeout": "00:00:05",
      "ExternalServiceTimeout": "00:01:00",
      "MessageQueueTimeout": "00:00:10"
    },
    "Bulkhead": {
      "MaxParallelization": 5,
      "MaxQueuedActions": 15
    }
  },
  "RabbitMQ": {
    "Host": "amqp://guest:guest@localhost:5672"
  }
}
