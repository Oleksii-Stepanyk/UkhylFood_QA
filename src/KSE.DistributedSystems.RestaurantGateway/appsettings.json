{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Resilience": {
    "CircuitBreaker": {
      "HandledEventsAllowedBeforeBreaking": 3,
      "DurationOfBreak": "00:00:30",
      "SamplingDuration": 60,
      "MinimumThroughput": 5
    },
    "Retry": {
      "MaxRetryAttempts": 3,
      "BaseDelay": "00:00:02",
      "MaxDelay": "00:00:30",
      "UseJitter": true
    },
    "Timeout": {
      "DefaultTimeout": "00:00:30",
      "DatabaseTimeout": "00:00:05",
      "ExternalServiceTimeout": "00:01:00",
      "MessageQueueTimeout": "00:00:10"
    },
    "Bulkhead": {
      "MaxParallelization": 5,
      "MaxQueuedActions": 15
    }
  },
  "OTLP_ENDPOINT_URL": "http://localhost:4317/",
  "ReverseProxy": {
    "Routes": {
      "restaurant": {
        "ClusterId": "restaurant",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "restaurant": {
        "Destinations": {
          "restaurant-api": {
            "Address": "http://restaurant-service:8080"
          }
        }
      },
      "orders": {
        "Destinations": {
          "orders-api": {
            "Address": "http://order-service:8080"
          }
        }
      }
    }
  }
}
