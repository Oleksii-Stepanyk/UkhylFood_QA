{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "KSE.DistributedSystems.OrderService": "Debug",
        "MassTransit": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*",
  "Resilience": {
    "CircuitBreaker": {
      "HandledEventsAllowedBeforeBreaking": 3,
      "DurationOfBreak": "00:00:30",
      "SamplingDuration": 60,
      "MinimumThroughput": 5
    },
    "Retry": {
      "MaxRetryAttempts": 3,
      "BaseDelay": "00:00:02",
      "MaxDelay": "00:00:30",
      "UseJitter": true
    },
    "Timeout": {
      "DefaultTimeout": "00:00:30",
      "DatabaseTimeout": "00:00:05",
      "ExternalServiceTimeout": "00:01:00",
      "MessageQueueTimeout": "00:00:10"
    },
    "Bulkhead": {
      "MaxParallelization": 5,
      "MaxQueuedActions": 15
    }
  },
  "ConnectionStrings": {
    "OrderServiceDb": "Host=localhost;Database=order-db;Username=postgres;Password=admin;"
  },
  "RabbitMQ": {
    "Host": "amqp://guest:guest@localhost:5672"
  }
}
